---
interface Props {
  title: string;
  description: string;
  href: string;
  image?: string;
  imageAlt?: string;
  badge?: string;
}
const { title, description, href, image, imageAlt = title, badge } = Astro.props;
---

<a href={href} class="sc">
  <div class="sc-img">
    {image
      ? <img src={image} alt={imageAlt} loading="lazy" />
      : <div class="sc-img-placeholder">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <path d="M21 15l-5-5L5 21"/>
          </svg>
          <span>Add screenshot</span>
        </div>
    }
    {badge && <span class="sc-badge">{badge}</span>}
  </div>
  <div class="sc-body">
    <h3 class="sc-title">{title}</h3>
    <p class="sc-desc">{description}</p>
    <span class="sc-cta">View docs →</span>
  </div>
</a>

<style>
.sc {
  display: flex;
  flex-direction: column;
  border: 1px solid var(--sl-color-hairline-light);
  border-radius: 0.75rem;
  overflow: hidden;
  text-decoration: none;
  background: var(--sl-color-bg-nav);
  transition: border-color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
}
.sc:hover {
  border-color: var(--sl-color-accent);
  box-shadow: 0 4px 24px rgba(0,0,0,0.35);
  transform: translateY(-2px);
}

/* image area */
.sc-img {
  position: relative;
  aspect-ratio: 16/9;
  overflow: hidden;
  background: var(--sl-color-gray-6, #1e1414);
  flex-shrink: 0;
}
.sc-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.sc-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  color: var(--sl-color-gray-5, #6b5b5b);
}
.sc-img-placeholder svg { width: 2rem; height: 2rem; }
.sc-img-placeholder span { font-size: 0.75rem; }

/* badge */
.sc-badge {
  position: absolute;
  top: 0.6rem;
  right: 0.6rem;
  background: var(--sl-color-accent);
  color: #fff;
  font-size: 0.7rem;
  font-weight: 600;
  padding: 0.15rem 0.5rem;
  border-radius: 999px;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

/* text body */
.sc-body {
  padding: 1rem 1.15rem 1.15rem;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.sc-title {
  margin: 0 0 0.4rem;
  font-size: 1rem;
  font-weight: 600;
  color: var(--sl-color-white);
  line-height: 1.3;
}
.sc-desc {
  margin: 0 0 auto;
  padding-bottom: 0.75rem;
  font-size: 0.85rem;
  color: var(--sl-color-gray-2, #c4b8b8);
  line-height: 1.55;
}
.sc-cta {
  font-size: 0.8rem;
  color: var(--sl-color-text-accent);
  font-weight: 500;
}
</style>
